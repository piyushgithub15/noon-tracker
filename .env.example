# Telegram Bot Configuration
# 1. Message @BotFather on Telegram and create a new bot with /newbot
# 2. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 3. Message your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Find your chat_id in the response
TELEGRAM_CHAT_ID=your_chat_id_here

# Price check interval in cron format (default: every 5 minutes)
CRON_SCHEDULE=*/5 * * * *

# Optional: Set to "true" to run a price check immediately on startup
CHECK_ON_STARTUP=true

# API server port (default: 3000)
PORT=3000
